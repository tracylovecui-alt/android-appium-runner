{
  "appiumHost": "127.0.0.1",
  "appiumPort": 4723,
  "appiumPath": "/",
  "deviceName": "Android Device",
  "apkPath": "C:\\path\\to\\your-app.apk",
  "appPackage": "com.example.app",
  "appActivity": ".MainActivity",
  "noReset": false,
  "autoGrantPermissions": true,
  "postLaunchWaitMs": 5000,
  "finalWaitMs": 3000,
  "screenshotLabel": "after-run",
  "actions": [
    {
      "type": "dismissPopups"
    },
    {
      "type": "input",
      "selector": "id=com.example.app:id/username",
      "value": "your_username"
    },
    {
      "type": "input",
      "selector": "id=com.example.app:id/password",
      "value": "your_password"
    },
    {
      "type": "click",
      "selector": "id=com.example.app:id/login"
    },
    {
      "type": "wait",
      "ms": 5000
    },
    {
      "type": "screenshot",
      "name": "after-login"
    }
  ]
}
